// Make if official
//

// Describe which changes effect which services
const restarters = {
    "aredn": {
        "aredn.@supernode[0].enable": "reboot",
        "aredn.@watchdog[0].enable": "hw_watchdog",
        "aredn.@beacon[0].enable": "fccid",
        "aredn.@remoterf[0].enable": "remote_rf",
        "aredn.@wan[0].web_access": "firewall",
        "aredn.@wan[0].ssh_access": "firewall",
        "aredn.@poe[0].passthrough": "poe",
        "aredn.@usb[0].passthrough": "pou",
        "aredn.@wan[0].lan_dhcp_route": [ "network-hard", "babel", "firewall" ],
        "aredn.@wan[0].mesh_to_local_wan": [ "network-hard", "babel", "wan_monitor" ],
        "aredn.@wan[0].lan_to_remote_wan": [ "network-hard", "babel" ],
        "aredn.@wan[0].monitor1": "wan_monitor",
        "aredn.@wan[0].monitor2": "wan_monitor",
        "aredn.@babel[0].protocol_buffer_size": "babel"
    },
    "babel": "babel",
    "dhcp": "dnsmasq",
    "dropbear": "dropbear",
    "firewall": "firewall",
    "network": [ "network", "remote_rf" ],
    "setup": {
        "setup.globals.dmz_mode": "reboot",
        "setup.@ntp[0].period": (o, n) => {
            switch (n) {
                case "continually":
                    system("/etc/init.d/sysntp enable > /dev/null 2>&1");
                    break;
                case "daily":
                    system("/etc/init.d/sysntp disable > /dev/null 2>&1");
                    if (fs.access("/etc/cron.hourly/update-clock")) {
                        fs.rename("/etc/cron.hourly/update-clock", "/etc/cron.daily/update-clock");
                    }
                    break;
                case "hourly":
                    system("/etc/init.d/sysntp disable > /dev/null 2>&1");
                    if (fs.access("/etc/cron.daily/update-clock")) {
                        fs.rename("/etc/cron.daily/update-clock", "/etc/cron.hourly/update-clock");
                    }
                    break;
                default:
                    break;
            }
        }
    },
    "system": [ "log", "system", "ntp" ],
    "wireless": {
        "any": "wireless",
        "wireless.@wifi-iface[0].mode": "reboot",
        "wireless.@wifi-device[0].channel": "lqm",
        "wireless.@wifi-device[0].macfilter": "reboot",
        "wireless.@wifi-iface[1].mode": "reboot",
        "wireless.@wifi-device[1].channel": "lqm",
        "wireless.@wifi-device[1].macfilter": "reboot",
    }
};

const specials = {};

for (let file in restarters) {
    const r = restarters[file];
    if (type(r) === "object") {
        for (let p in r) {
            const p3 = split(p, ".");
            if (length(p3) === 3) {
                specials[p] = c.get(p3[0], p3[1], p3[2]);
            }
        }
    }
}

// Get the new config files
const nfiles = {};
map(fs.lsdir("/tmp/new_config"), file => nfiles[file] = true);

// Remove files we no longer need
map(fs.lsdir("/tmp/config"), file => {
    if (!nfiles(file)) {
        fs.unlink(`/etc/config/${file}`);
        if (file !== "ubootenv") {
            changes.reboot = true;
        }
    }
});

// Compare the new config against the old and restart services as necessary
const oc = uci.cursor();
for (let file in nfiles) {
    const ffile = `/tmp/new_config/${file}`;
    if (filecopy(ffile, `/etc/config/${file}`)) {
        let r = restarters[file];
        if (!r) {
            r = { "any": "reboot" };
        }
        else if (type(r) !== "object") {
            r = { "any": r };
        }
        for (let p in r) {
            const p3 = split(p, ".");
            if (p === "any" || specials[p] != oc.get(p3[0], p3[1], p3[2])) {
                const c = r[p];
                switch (type(c)) {
                    case "string":
                        changes[c] = true;
                        break;
                    case "array":
                        map(c, k => changes[k] = true);
                        break;
                    case "function":
                        if (p === "any") {
                            c();
                        }
                        else {
                            c(specials[p], oc.get(p3[0], p3[1], p3[2]));
                        }
                        break;
                    default:
                        break;
                }
            }
        }
    }
}

fs.rmdir("/tmp/new_config");

nvram.set("hsmmmesh", "settings", "node", node);
nvram.set("hsmmmesh", "settings", "tactical", tactical);

// Set file flags for whichever parts of the system require a restart/reboot
for (let k in changes) {
    if (changes[k]) {
        fs.mkdir("/tmp/reboot-required");
        fs.writefile(`/tmp/reboot-required/${k}`, `${changes[k]}`);
    }
}

exit(0);
