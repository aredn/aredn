ROOT="/tmp/reboot-required"
SERVICES="log system firewall network-hard network wireless dnsmasq dropbear lqm remote_rf hw_watchdog fccid manager babel arednlink localservices poe pou ntp"

ignore=0
force=0
if [ "$1" = "--force" ]; then
  shift
  ignore=1
  force=1
fi
if [ "$1" = "--ignore-reboot" ]; then
  shift
  ignore=1
fi

# Anything to do?
if [ ! -d $ROOT -a $force = 0 ]; then
  exit 0
fi

# If we have to reboot, do nothing (unless ignored)
if [ -f $ROOT/reboot -a $ignore = 0 ]; then
  exit 1
fi

# Override services to restart
if [ "$*" != "" ]; then
  SERVICES="$*"
fi

# If we are restarting the network and babel, shutdown babel first so the node leaves the network politely
# Later we will restart babel after the network restarts
if [ -f $ROOT/network -a -f $ROOT/babel -a "$*" = "" ]; then
  echo "Stopping babel"
  /etc/init.d/babel stop > /dev/null 2>&1
fi

for srv in $SERVICES
do
  if [ -f $ROOT/$srv -o $force = 1 ]; then
    echo "Reloading $srv"
    if [ $srv = "wireless" ]; then
      /sbin/wifi down > /dev/null 2>&1
      /sbin/wifi up > /dev/null 2>&1
    elif [ $srv = "localservices" ]; then
      /etc/local/services > /dev/null 2>&1
    elif [ $srv = "poe" ]; then
      /usr/local/bin/poe_passthrough $(/sbin/uci -q get aredn.@poe[0].passthrough) > /dev/null 2>&1
    elif [ $srv = "pou" ]; then
      /usr/local/bin/usb_passthrough $(/sbin/uci -q get aredn.@usb[0].passthrough) > /dev/null 2>&1
    elif [ $srv = "ntp" ]; then
      if /etc/init.d/sysntpd enabled; then
        /etc/init.d/sysntpd start
      else
        /etc/init.d/sysntpd stop
      fi
    elif [ $srv = "network-hard" ]; then
      /etc/init.d/network restart
      rm -f $ROOT/network
    elif [ $srv = "network" ]; then
      /etc/init.d/network reload
    elif [ $srv = "lqm" -o $srv = "hw_watchdog" -o $srv = "fccid" -o $srv = "remote_rf" -o $srv = "wan_monitor" ]; then
      touch /tmp/mgr/$srv
    elif [ $srv = "babel-hard" ]; then
      /etc/init.d/babel stop > /dev/null 2>&1
      rm -f /etc/state/babel-state
      /etc/init.d/babel start > /dev/null 2>&1
    elif [ $srv = "arednlink" ]; then
      /usr/local/bin/arednlink-update
    elif [ $srv = "arednlink-hard" ]; then
      /etc/init.d/arednlink restart > /dev/null 2>&1
    elif [ -x /etc/init.d/$srv ]; then
      /etc/init.d/$srv restart > /dev/null 2>&1
    fi
    rm -f $ROOT/$srv
  fi
done
if [ "$(ls -A /tmp/mgr)" != "" ]; then
  kill -SIGUSR1 $(cat /var/run/manager.pid)
fi

rmdir --ignore-fail-on-non-empty $ROOT 2> /dev/null
if [ -d $ROOT ]; then
  exit 1
fi

exit 0
