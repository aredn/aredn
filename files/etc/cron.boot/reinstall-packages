import * as fs from "fs";
import * as uci from "uci";

const packageStore = "/etc/package_store";
const packageCatalog = `${packageStore}/catalog.json`;

function apk_with_retry(arg)
{
	for (let i = 0; i < 5; i++) {
		if (system(`/usr/bin/apk ${arg} 2>/dev/null`) != 255) {
			break;
		}
		sleep(5000);
	}
}

apk_with_retry("info > /etc/permpkg");

if (fs.access(packageCatalog)) {
	// Make sure we can contact the package server before proceeding.
	// We will wait a few minutes before going ahead anyway
	const pkghost = match(uci.cursor().get("aredn", "@downloads[0]", "packages_default"), /^https?:\/\/([^/]+)/)[1];
	for (let i = 0; i < 5; i++) {
		if (system(`ping -q -c 1 -W 5 ${pkghost} > /dev/null 2>&1`) == 0) {
			break;
		}
		print("Failed to contact package server - retry in 60 seconds\n");
		sleep(60000);
	}

    apk_with_retry("update");
    const catalog = json(fs.readfile(packageCatalog));
	for (let pkg in catalog.installed) {
		const state = catalog.installed[pkg];
        if (state == "local") {
			fs.unlink(`${packageStore}/${pkg}.ipk`); // Remove the old format packages
            const file = `${packageStore}/${pkg}.apk`;
            if (fs.access(file)) {
                apk_with_retry(`add --allow-untrusted ${file}`);
			}
			else {
				delete catalog.installed[pkg];
			}
		}
        else if (state == "global") {
            apk_with_retry(`add ${pkg}`);
		}
	}
	fs.writefile(packageCatalog, sprintf("%J", catalog));
}

// Don't do this again
fs.unlink("/etc/cron.boot/reinstall-packages");
