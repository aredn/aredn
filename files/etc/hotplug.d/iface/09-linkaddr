#!/bin/sh
# Give specific interfaces unique ipv4 & ipv6 link local address

RETRIES=10
TESTS=2

case "${INTERFACE}" in
    wifi*|wg*|xlink*|remoterf*)
        if "${ACTION}" = "ifup"; then
            if ! /sbin/ip -4 -o addr show dev ${DEVICE} scope link | /bin/grep -q "inet "; then
                n=0
                IP=$(printf '169.254.%d.%d' 0x$(cat /sys/class/net/${DEVICE}/address | cut -d: -f5) 0x$(cat /sys/class/net/${DEVICE}/address | cut -d: -f6))
                while [ ${n} -lt ${RETRIES} ]; do
                    if ! /sbin/ip -4 -o addr show | /bin/grep -qw ${IP} && /usr/sbin/arping -q -c ${TESTS} -D -I ${DEVICE} ${IP}; then
                        /sbin/ip -4 addr add ${IP}/16 dev ${DEVICE} brd + scope link
                        break
                    fi
                    n=$((n+1))
                    IP=$(/usr/bin/printf 169.254.$(((${RANDOM} % 254) + 1)).$((${RANDOM} % 256)))
                done
            fi
            if ! /sbin/ip -6 -o addr show dev ${DEVICE} scope link | /bin/grep -q "inet6 fe80:"; then
                IP=$(/usr/bin/printf "fe80::%04x:%04x:%04x:%04x" ${RANDOM} ${RANDOM} ${RANDOM} ${RANDOM})
                /sbin/ip -6 addr add ${IP}/64 dev ${DEVICE} scope link 2>/dev/null
            fi
        fi
        ;;
    *)
        ;;
esac
