#
# Copy the QoS information from the wireguard payload onto the wireguard encrypted
# packet so we can prioritize the traffic correctly
#
id=1
for dscp in cs0 cs1 cs2 cs3 cs4 cs5 cs6 cs7 af11 af12 af13 af21 af22 af23 af31 af32 af33 af41 af42 af43 ef
do
  nft insert rule inet fw4 mangle_prerouting iifname "wg*" ip dscp ${dscp} meta mark set mark or ${id}
  nft insert rule inet fw4 mangle_postrouting meta mark and 0xff == ${id} ip dscp set ${dscp}
  id=$((id+1))
done

#
# Setup cake on each physical interface so they'll respect the QoS marks on general and tunneled packets
#
for i in /sys/class/net/*/device; do
  dev=$(basename ${i%/device})
  tc qdisc replace dev ${dev} root cake diffserv4 nowash ack-filter nat
done
